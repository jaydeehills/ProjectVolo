# === Required ===
ANTHROPIC_API_KEY=sk-ant-xxxxx          # Claude API key for probability estimation

# === Optional ===
POLYMARKET_API_KEY=                      # Polymarket API key (not required for public data)
AGENT_ENABLED=true                       # Set to "false" to pause all signal generation
ESTIMATES_DB_PATH=estimates.db           # Path to SQLite database file
