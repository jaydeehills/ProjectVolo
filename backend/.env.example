# === Required ===
ANTHROPIC_API_KEY=sk-ant-xxxxx          # get one at console.anthropic.com

# === Server ===
HOST=0.0.0.0                            # bind address (0.0.0.0 = all interfaces)
PORT=8000                               # API server port

# === Optional ===
ESTIMATES_DB_PATH=estimates.db          # path to SQLite estimates cache (default: working dir)
